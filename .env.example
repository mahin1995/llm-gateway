NODE_ENV=development
PORT=3000
CLIENT_DEV_ORIGIN=http://localhost:5173

DATABASE_URL=postgresql://postgres:password@localhost:5432/llm_gateway?schema=public

OPENROUTER_API_KEY=replace_with_openrouter_key
OPENROUTER_MANAGEMENT_KEY=replace_with_openrouter_management_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=LLM Gateway
SESSION_SECRET=change_this_to_a_long_random_value

# Seed creates this gateway key hash for local testing.
DEV_GATEWAY_API_KEY=lgw_dev_key
DEV_ADMIN_PASSWORD=admin12345
